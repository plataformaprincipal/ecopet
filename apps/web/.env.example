APP_URL=http://localhost:3000
DATABASE_URL=postgresql://ecopet:ecopet_dev@localhost:5432/ecopet?schema=public
DIRECT_URL=postgresql://ecopet:ecopet_dev@localhost:5432/ecopet?schema=public
AUTH_SECRET=change-me-in-production-auth-secret

# Fallback local para upload em desenvolvimento (anexos de chat, avatares, etc.)
UPLOAD_DEV_FALLBACK=1

# ─── Recuperação de senha (exclusivamente Resend — sem SMTP) ───
# Substitua re_xxxxxxxxx pela sua chave real em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=EcoPet

# Testes automatizados de OTP (servidor de testes — não usar em produção)
AUTH_TEST_EXPOSE_OTP=
AUTH_TEST_OTP_TTL_MS=
PASSWORD_RESET_TEST_OTP_FILE=

# ─── Recuperação por SMS (Twilio) ───
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PHONE_SMS_RECOVERY_ENABLED=1

# Legado / outros provedores SMS (opcional)
SMS_API_KEY=
SMS_SENDER=EcoPet

# Destinatário para npm run test:mail (legado — outros e-mails transacionais)
TEST_EMAIL=

# ─── SMTP legado (outros e-mails transacionais — NÃO usado na recuperação de senha) ───
MAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=

# Gmail real (senha de APP — https://myaccount.google.com/apppasswords):
# npm run setup:smtp -- --user=seu@gmail.com --pass="senha-de-app" --test=seu@gmail.com
#
# Dev local (Maildev): npm run setup:smtp:dev && npm run mail:up
