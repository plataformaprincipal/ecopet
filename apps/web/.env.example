# EcoPet Web — variáveis locais
# Lista COMPLETA: ../../.env.example (raiz do monorepo)
# Catálogo no código: src/lib/env-registry.ts
#
# Sincronize do .env raiz: npm run sync:env

# ─── Mínimo local (copie da raiz ou do Supabase) ───
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upload local em dev
UPLOAD_DEV_FALLBACK=1

# Recuperação de senha
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Cloudinary (produção)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# SMS (opcional)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# PHONE_SMS_RECOVERY_ENABLED=1

# TalkJS (opcional)
# NEXT_PUBLIC_TALKJS_APP_ID=
# TALKJS_SECRET_KEY=
