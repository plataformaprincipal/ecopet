# EcoPet Web — variáveis locais
# Lista COMPLETA: ../../.env.example (raiz do monorepo)
# Catálogo no código: src/lib/env-registry.ts
#
# Sincronize do .env raiz: npm run sync:env

# --- Mínimo local (copie da raiz ou do Supabase) ---
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenAI (somente servidor — NUNCA NEXT_PUBLIC_) ---
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MAX_OUTPUT_TOKENS=1024
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_DAILY_USER_LIMIT=50
OPENAI_MONTHLY_BUDGET_CENTS=500

# --- Resend / e-mail ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# --- Twilio / SMS ---
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- TalkJS ---
NEXT_PUBLIC_TALKJS_APP_ID=
TALKJS_SECRET_KEY=

# --- Cloudinary / upload ---
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_DEV_FALLBACK=1

# --- Mercado Pago ---
PAYMENT_PROVIDER=none
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Build ---
NODE_OPTIONS=--max-old-space-size=8192
