{
  "name": "@ecopet/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ../../scripts/prisma-generate-safe.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "npm run generate -w @ecopet/database",
    "db:push": "npm run push -w @ecopet/database",
    "db:setup": "node ../../scripts/ensure-postgres.mjs && npm run db:push",
    "test:cep": "node --import tsx --test src/lib/address/cep-service.test.ts",
    "test:cnpj": "node --import tsx --test src/lib/integrations/cnpj/cnpj-service.test.ts",
    "test:password": "node --import tsx --test src/lib/password/validate-strong-password.test.ts",
    "test:partner:rules": "node --import tsx --test src/lib/partner/operation-rules.test.ts src/lib/partner/document-validation.test.ts",
    "test:registration:rules": "node --import tsx --test src/lib/registration/collect-step-errors.test.ts"
  },
  "dependencies": {
    "@ecopet/database": "*",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.12.1",
    "jose": "^6.0.11",
    "libphonenumber-js": "^1.13.7",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.14.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.0",
    "twilio": "^6.0.2",
    "zod": "^3.25.28",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
