# Copie para .env.smtp.local ou configure via npm:
#
# Gmail (senha de APP — https://myaccount.google.com/apppasswords):
# npm run setup:smtp -- --user=seu@gmail.com --pass="senha-de-app" --test=seu@gmail.com
#
# Dev local: npm run setup:smtp:dev && npm run mail:up

MAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=
TEST_EMAIL=
