  PAYMENT
  PET
  PARTNER
  ONG
  TECHNICAL
  OTHER
}

enum MessageReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum ConversationType {
  SUPPORT
  CLIENT_ONG
  CLIENT_PARTNER
  DIRECT
  SYSTEM
  CLIENT_CLIENT
  CLIENT_NGO
  CLIENT_ECOPET
  PARTNER_CLIENT
  PARTNER_PARTNER
  PARTNER_NGO
  PARTNER_ECOPET
  NGO_CLIENT
