  id          String            @id @default(cuid())
  ownerId     String
  provider    String
  name        String
  status      IntegrationStatus @default(DISCONNECTED)
  config      Json?
  permissions Json?
  lastSyncAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  logs        IntegrationLog[]

  @@index([ownerId, provider])
}

model IntegrationLog {
  id            String      @id @default(cuid())
  integrationId String
  action        String
  status        String
  message       String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
}

/// Log de integrações da plataforma (upload, e-mail, pagamento, IA, mapas, etc.)
model PlatformIntegrationLog {
  id              String   @id @default(cuid())
  integrationName String
  provider        String
  action          String
  status          String
  errorCode       String?
  message         String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([integrationName, createdAt])
  @@index([provider, createdAt])
  @@index([status, createdAt])
}

/// Pagamentos reais — nunca marcar SUCCEEDED sem webhook do provedor
model Payment {
  id         String   @id @default(cuid())
  orderId    String
  provider   String
  externalId String?
  amount     Float
  currency   String   @default("BRL")
  status     String   @default("PENDING")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events     PaymentEvent[]

  @@index([orderId])
  @@index([provider, status])
  @@index([externalId])
}

model PaymentEvent {
  id         String   @id @default(cuid())
  paymentId  String?
  orderId    String?
  provider   String
  eventType  String
  status     String
  errorCode  String?
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  payment    Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt])
  @@index([orderId, createdAt])
  @@index([provider, createdAt])
}

model OperationalRobot {
  id          String      @id @default(cuid())
  ownerId     String
  profileType String
  domain      RobotDomain
  name        String
  description String?
  config      Json?
  isActive    Boolean     @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime    @default(now())
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks       RobotTask[]
  logs        RobotLog[]
  alerts      RobotAlert[]

  @@index([ownerId, profileType])
}

model SystemMetric {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  metricKey String
  value     Float
  metadata  Json?

  @@index([metricKey, date])
}

model FinancialTransaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([type, category])
}

// ─── Saldo ECOPET (Carteira Digital) ───

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("BRL")
  createdAt DateTime @default(now())
