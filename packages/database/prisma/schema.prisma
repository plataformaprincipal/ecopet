generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TUTOR
  VETERINARIAN
  CLINIC
  PETSHOP
  SELLER
  SERVICE_PROVIDER
  ONG
  ADMIN
  GESTOR
  DELIVERY
  INFLUENCER
  PARTNER
}

enum AccountStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum PetSpecies {
  DOG
  CAT
  BIRD
  RODENT
  REPTILE
  FISH
  OTHER
}

enum PetSize {
  MINI
  SMALL
  MEDIUM
  LARGE
  GIANT
}

enum PostType {
  PHOTO
  VIDEO
  REEL
  STORY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  READY_PICKUP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  PICKED_UP
  CANCELLED
  REFUNDED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PRO
  CLINIC
  BUSINESS
}

enum BadgeType {
  VERIFIED
  PREMIUM
  VETERINARIAN
}

enum AdoptionStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

enum ServiceType {
  READY_SERVICE
  CUSTOM_SERVICE
}

enum ReadyServiceCategory {
  BATH_GROOMING
  VET_CONSULTATION
  VACCINATION
  DOG_WALKER
  PET_SITTER
  TRAINING
  BOARDING
  PET_TRANSPORT
}

enum CustomRequestUrgency {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum CustomRequestStatus {
  OPEN
  IN_REVIEW
  QUOTED
  CLOSED
}

enum ApprovalType {
  CLIENT
  PARTNER
  ONG
  PRODUCT
  SERVICE
  CAMPAIGN
  ADVERTISEMENT
  INTEGRATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ConversationType {
  CLIENT_CLIENT
  CLIENT_PARTNER
  CLIENT_NGO
  CLIENT_ECOPET
  PARTNER_CLIENT
  PARTNER_PARTNER
  PARTNER_NGO
  PARTNER_ECOPET
  NGO_CLIENT
  NGO_PARTNER
  NGO_ECOPET
  INTERNAL
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
  PRIORITY
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  QUOTE
  SYSTEM
  AI
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  NEGOTIATING
  CONVERTED
  COMPLETED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  MODERATE
  ASSIGN
  SYNC
}

enum ContentApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

enum RobotDomain {
  HEALTH
  FINANCE
  AGENDA
  LEISURE
  SHOPPING
  PETS
  INTEGRATIONS
  COMMERCIAL
  STOCK
  PRODUCTION
  MARKETING
  QUALITY
  LOGISTICS
  LEGAL
  HR
  AGROPET
  AI
  CAMPAIGNS
  DONATIONS
  RESCUE
  PROJECTS
  VOLUNTEERS
  EVENTS
  MONITORING
  AUDIT
  MODERATION
  SECURITY
  GROWTH
}

enum DeliveryMethod {
  PICKUP_LOCAL
  DELIVERY_LOCAL
  DELIVERY_REGIONAL
  DELIVERY_NATIONAL
  DELIVERY_OWN
  DELIVERY_PARTNER_LOGISTICS
  DELIVERY_SCHEDULED
  PICKUP_SCHEDULED
}

enum PaymentMethod {
  CARD
  PIX
  CASH
  TRANSFER
  WALLET
  BOLETO
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  CASHBACK
  BONUS
  CAMPAIGN
  DONATION
  TRANSFER_IN
  TRANSFER_OUT
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RefundDestination {
  CARD
  WALLET
}

enum ServiceFulfillmentMode {
  IN_PERSON
  HOME
  ONLINE
}

enum AdvisoryPlanType {
  PARTNER_BUSINESS
  NGO_SOCIAL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  passwordHash  String
  name          String
  cpf           String?   @unique
  birthDate     DateTime?
  phone         String?
  avatar        String?
  gender        String?
  role          UserRole  @default(TUTOR)
  accountStatus AccountStatus @default(ACTIVE)
  accountStatusReason String?
  bio           String?
  isVerified    Boolean   @default(false)
  isPremium     Boolean   @default(false)
  isOrgAdmin    Boolean   @default(false)
  isBootstrapUser Boolean @default(false)
  isMasterAdmin Boolean   @default(false)
  firstLoginRequired Boolean @default(false)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  passwordChangedAt DateTime?
  badges        Json?
  socialLinks   Json?
  preferences   Json?
  documents     Json?
  termsAcceptedAt DateTime?
  lgpdAcceptedAt  DateTime?
  latitude      Float?
  longitude     Float?
  darkMode      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  address       Address?
  pets          Pet[]
  ongPets       Pet[]     @relation("PetOng")
  protectorPets Pet[]     @relation("PetProtector")
  petEventsAuthored PetEvent[] @relation("PetEventAuthor")
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  savedPosts    SavedPost[]
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Follower")
  notifications Notification[]
  sentMessages  Message[] @relation("Sender")
  conversations ConversationParticipant[]
  orders        Order[]
  wallet        Wallet?
  refunds       Refund[]
  advisorySubscription AdvisorySubscription?
  partnerLogistics PartnerLogisticsConfig? @relation("PartnerLogistics")
  cart          Cart?
  favorites     Favorite[]
  subscriptions Subscription[]
  veterinarianProfile VeterinarianProfile?
  clinicProfile       ClinicProfile?
  petshopProfile      PetshopProfile?
  ongProfile          OngProfile?
  tutorProfile        TutorProfile?
  sellerProfile       SellerProfile?
  serviceProviderProfile ServiceProviderProfile?
  adminProfile        AdminProfile?
  gestorProfile       GestorProfile?
  products            Product[] @relation("SellerProducts")
  services            Service[] @relation("ProviderServices")
  customServiceRequests CustomServiceRequest[] @relation("TutorRequests")
  reviews             Review[]
  adoptionListings    AdoptionListing[]
  medicalRecords      MedicalRecord[] @relation("RecordAuthor")
  aiSessions          AiSession[]
  gamification        GamificationProfile?
  rbacAssignments     UserRbacAssignment[]
  auditLogs           AuditLog[] @relation("AuditActor")
  approvalRequests    ApprovalRequest[] @relation("ApprovalRequester")
  approvalReviews     ApprovalRequest[] @relation("ApprovalReviewer")
  supportTickets      SupportTicket[] @relation("TicketRequester")
  assignedTickets     SupportTicket[] @relation("TicketAssignee")
  contentReports      ContentReport[] @relation("ReportAuthor")
  reviewedReports     ContentReport[] @relation("ReportReviewer")
  integrations        Integration[]
  operationalRobots   OperationalRobot[]
  customQuotesSent    CustomQuote[] @relation("QuoteRequester")
  customQuotesReceived CustomQuote[] @relation("QuoteProvider")
  department          Department? @relation(fields: [departmentId], references: [id])
  departmentId        String?
  sessions            UserSession[]
  loginLogs           LoginLog[]
  passwordResets      PasswordReset[]
  securityEvents      SecurityEvent[]
  gestorInvitesSent   GestorInvite[] @relation("InviteSender")
  platformDocuments   PlatformDocument[]
  verificationCodes   VerificationCode[]
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  organizationUnits   OrganizationMember[]
  consentRecords      ConsentRecord[]
  lgpdRequests        LgpdRequest[]
  platformEvents      PlatformEvent[] @relation("EventActor")
  workflowInstances   WorkflowInstance[] @relation("WorkflowOwner")
  costEntries         CostEntry[]
  entityVersions      EntityVersion[] @relation("VersionAuthor")
  governanceInsights  GovernanceInsight[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([organizationId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String  @unique
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  country    String  @default("BR")
  latitude   Float?
  longitude  Float?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pet {
  id                String     @id @default(cuid())
  ownerId           String
  ongId             String?
  protectorId       String?
  name              String
  photo             String?
  photos            Json?
  species           PetSpecies
  breed             String?
  size              PetSize?
  sex               String?
  birthDate         DateTime?
  weight            Float?
  color             String?
  neutered          Boolean    @default(false)
  hasMicrochip      Boolean    @default(false)
  microchip         String?
  behavior          String?
  temperament       String?
  rescueHistory     String?
  specialNeeds      String?
  dietaryRestriction String?
  allergiesText     String?
  diet              String?
  activityLevel     String?
  notes             String?
  documents         Json?
  qrCodeSlug        String?    @unique
  publicProfile     Boolean    @default(false)
  locationAddress   String?
  locationCity      String?
  locationState     String?
  isLost            Boolean    @default(false)
  lostAt            DateTime?
  lostCity          String?
  lostContact       String?
  availableForAdoption Boolean @default(false)
  adoptionReason    String?
  adoptionRequirements String?
  adoptionCity      String?
  adoptionFee       Float?
  aiProfile         Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  owner             User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ong               User?      @relation("PetOng", fields: [ongId], references: [id], onDelete: SetNull)
  protector         User?      @relation("PetProtector", fields: [protectorId], references: [id], onDelete: SetNull)
  vaccinations      Vaccination[]
  medications       Medication[]
  allergies         Allergy[]
  exams             Exam[]
  consultations     Consultation[]
  medicalRecords    MedicalRecord[]
  weightRecords     PetWeightRecord[]
  media             PetMedia[]
  events            PetEvent[]
  posts             Post[]

  @@index([ownerId])
  @@index([ongId])
  @@index([isLost])
  @@index([availableForAdoption])
}

model PetWeightRecord {
  id         String   @id @default(cuid())
  petId      String
  weight     Float
  recordedAt DateTime @default(now())
  notes      String?
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, recordedAt])
}

model PetMedia {
  id         String   @id @default(cuid())
  petId      String
  type       String
  url        String
  caption    String?
  recordedAt DateTime @default(now())
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model PetEvent {
  id          String   @id @default(cuid())
  petId       String
  eventType   String
  title       String
  description String?
  metadata    Json?
  createdById String?
  createdAt   DateTime @default(now())
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("PetEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([petId, createdAt])
}

model Vaccination {
  id           String   @id @default(cuid())
  petId        String
  name         String
  manufacturer String?
  batch        String?
  date         DateTime
  nextDue      DateTime?
  veterinarian String?
  notes        String?
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Medication {
  id        String   @id @default(cuid())
  petId     String
  name      String
  dosage    String?
  frequency String?
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Allergy {
  id       String @id @default(cuid())
  petId    String
  allergen String
  severity String?
  pet      Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Exam {
  id        String   @id @default(cuid())
  petId     String
  type      String
  date      DateTime
  result    String?
  fileUrl   String?
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Consultation {
  id            String   @id @default(cuid())
  petId         String
  veterinarianId String?
  date          DateTime
  type          String
  notes         String?
  prescription  String?
  pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id               String   @id @default(cuid())
  petId            String
  authorId         String
  type             String
  title            String
  content          String?
  recordDate       DateTime @default(now())
  veterinarianName String?
  clinicName       String?
  fileUrl          String?
  attachments      Json?
  createdAt        DateTime @default(now())
  pet              Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  author           User     @relation("RecordAuthor", fields: [authorId], references: [id])
}

model TutorProfile {
  id                String @id @default(cuid())
  userId            String @unique
  petCount          Int?
  primaryInterests  Json?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VeterinarianProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  crmv                  String   @unique
  crmvState             String?
  specialties           Json?
  description           String?
  certificates          Json?
  experience            Int?
  averageConsultationPrice Float?
  onlineAvailable       Boolean  @default(true)
  inPersonAvailable     Boolean  @default(true)
  professionalAddress   String?
  documents             Json?
  schedule              Json?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClinicProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tradeName            String
  cnpj                 String   @unique
  technicalResponsible String?
  responsibleCrmv      String?
  photos               Json?
  services             Json?
  emergency            Boolean  @default(false)
  team                 Json?
  hours                Json?
  documents            Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PetshopProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tradeName      String
  cnpj           String   @unique
  responsible    String?
  banner         String?
  photos         Json?
  sellsProducts  Boolean  @default(true)
  offersServices Boolean  @default(false)
  categories     Json?
  delivery       Boolean  @default(true)
  pickup         Boolean  @default(true)
  hours          Json?
  documents      Json?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id                String @id @default(cuid())
  userId            String @unique
  tradeName         String
  cnpj              String @unique
  responsible       String
  productCategories Json?
  deliveryPolicy    String?
  exchangePolicy    String?
  bankData          Json?
  documents         Json?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceProviderProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  documentType   String
  documentNumber String  @unique
  serviceTypes   Json
  serviceArea    String?
  homeService    Boolean @default(false)
  startingPrice  Float?
  availability   String?
  documents      Json?
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OngProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  name             String
  tradeName        String?
  documentType     String?
  cnpj             String  @unique
  responsible      String
  photos           Json?
  requirements     String?
  actionTypes      Json?
  animalCapacity   Int?
  acceptsDonations Boolean @default(true)
  documents        Json?
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id             String @id @default(cuid())
  userId         String @unique
  corporateEmail String?
  jobTitle       String
  accessLevel    String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GestorProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  corporateEmail String?
  jobTitle       String
  hierarchyLevel Int     @default(1)
  departmentId   String?
  employeeCode   String?
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  petId     String?
  type      PostType @default(PHOTO)
  content   String?
  mediaUrls Json?
  isPrivate Boolean  @default(false)
  isHidden  Boolean  @default(false)
  isModerated Boolean @default(false)
  moderationNotes String?
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?
  shares    Int      @default(0)

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pet       Pet?     @relation(fields: [petId], references: [id])
  comments  Comment[]
  likes     Like[]
  savedBy   SavedPost[]
  hashtags  PostHashtag[]

  @@index([authorId])
  @@index([createdAt])
}

model Hashtag {
  id     String @id @default(cuid())
  tag    String @unique
  count  Int    @default(0)
  posts  PostHashtag[]
}

model PostHashtag {
  postId    String
  hashtagId String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  @@id([postId, hashtagId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([postId, userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
}

model ProductCategory {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  icon     String?
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  sellerId    String
  categoryId  String?
  name        String
  description String
  price       Float
  comparePrice Float?
  images      Json?
  stock       Int      @default(0)
  sku         String?
  isSponsored Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  approvalStatus ContentApprovalStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller      User     @relation("SellerProducts", fields: [sellerId], references: [id])
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  reviews     Review[]

  @@index([sellerId])
  @@index([categoryId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  @@unique([cartId, productId])
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       Int            @unique
  userId            String
  partnerId         String?
  status            OrderStatus    @default(PENDING)
  fulfillmentStatus OrderStatus    @default(PENDING)
  total             Float
  shippingCost      Float            @default(0)
  discount          Float            @default(0)
  shippingAddress   Json
  alternateAddress  Json?
  deliveryMethod    DeliveryMethod @default(DELIVERY_LOCAL)
  paymentMethod     PaymentMethod  @default(PIX)
  scheduledAt       DateTime?
  deliveryNotes     String?
  pickupInstructions String?
  pickupQrCode      String?
  thirdPartyPickup  Json?
  serviceMode       ServiceFulfillmentMode?
  onlineLink        String?
  carrierName       String?
  stripePaymentId   String?
  walletTransactionId String?
  trackingCode      String?
  estimatedDelivery DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User           @relation(fields: [userId], references: [id])
  items             OrderItem[]
  fulfillments      OrderFulfillment[]
  statusHistory     OrderStatusHistory[]
  refunds           Refund[]

  @@index([userId])
  @@index([partnerId])
  @@index([status])
}

model OrderFulfillment {
  id              String         @id @default(cuid())
  orderId         String
  partnerId       String
  status          OrderStatus    @default(PENDING)
  deliveryMethod  DeliveryMethod
  trackingCode    String?
  carrierName     String?
  estimatedAt     DateTime?
  deliveredAt     DateTime?
  notes           String?
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([partnerId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  serviceId String?
  quoteId   String?
  itemType  String  @default("product")
  name      String
  quantity  Int
  price     Float
  partnerId String?
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  @@unique([productId, userId])
}

model Favorite {
