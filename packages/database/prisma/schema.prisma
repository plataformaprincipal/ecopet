  HIDDEN
  REPORTED
}

enum ApprovalType {
  CLIENT
  PARTNER
  ONG
  PRODUCT
  SERVICE
  CAMPAIGN
  ADVERTISEMENT
  INTEGRATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION
}

enum TicketStatus {
  OPEN
