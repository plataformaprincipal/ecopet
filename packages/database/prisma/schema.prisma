// ─── Gestor: IoT ───

model IotDevice {
  id           String   @id @default(cuid())
  name         String
  deviceType   String
  ownerType    String
  ownerId      String
  userId       String?
  petId        String?
  agroUnitId   String?
  status       String   @default("offline")
  location     String?
  latitude     Float?
  longitude    Float?
  battery      Float?
  isDemo       Boolean  @default(true)
  lastReading  DateTime?
  lastSyncAt   DateTime?
  virtualFence Json?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  pet          Pet?     @relation(fields: [petId], references: [id], onDelete: SetNull)
  agroUnit     AgroUnit? @relation(fields: [agroUnitId], references: [id], onDelete: SetNull)
  readings     IotReading[]
  alerts       IotAlert[]
  logs         IotDeviceLog[]
  automations  IotAutomation[]

  @@index([userId])
  @@index([petId])
  @@index([agroUnitId])
  @@index([ownerId])
  @@index([ownerType])
}

model IotReading {
  id         String    @id @default(cuid())
  deviceId   String
  metricKey  String
  type       String?
  value      Float
  unit       String?
  userId     String?
  petId      String?
  agroUnitId String?
  latitude   Float?
  longitude  Float?
  battery    Float?
  metadata   Json?
  recordedAt DateTime  @default(now())
  device     IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
}

model IotAlert {
  id        String    @id @default(cuid())
  deviceId  String
  severity  String
  message   String
  resolved  Boolean   @default(false)
  createdAt DateTime  @default(now())
  device    IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, resolved])
}

model IotDeviceLog {
  id        String    @id @default(cuid())
  deviceId  String
  action    String
  metadata  Json?
  createdAt DateTime  @default(now())
  device    IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model IotAutomation {
  id        String    @id @default(cuid())
  deviceId  String?
  userId    String
  name      String
  trigger   String
  action    String
  isActive  Boolean   @default(true)
  metadata  Json?
  createdAt DateTime  @default(now())
  device    IotDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AgroUnit {
  id        String       @id @default(cuid())
  ownerId   String
  name      String
  location  String?
  areaHa    Float?
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  devices   IotDevice[]
  sensors   AgroSensor[]

  @@index([ownerId])
}

model AgroSensor {
  id         String   @id @default(cuid())
  agroUnitId String
  name       String
  sensorType String
  status     String   @default("offline")
  battery    Float?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agroUnit   AgroUnit @relation(fields: [agroUnitId], references: [id], onDelete: Cascade)

  @@index([agroUnitId])
}

// ─── Gestor: Robôs (extensão) ───

model RobotTask {
  id        String   @id @default(cuid())
  robotId   String
  taskType  String
  status    String   @default("PENDING")
  result    Json?
  scheduledAt DateTime?
  executedAt  DateTime?
  robot     OperationalRobot @relation(fields: [robotId], references: [id], onDelete: Cascade)
}

model RobotLog {
  id        String   @id @default(cuid())
  robotId   String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  robot     OperationalRobot @relation(fields: [robotId], references: [id], onDelete: Cascade)
}

model RobotAlert {
  id        String   @id @default(cuid())
  robotId   String
  severity  String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  robot     OperationalRobot @relation(fields: [robotId], references: [id], onDelete: Cascade)
}

// ─── Gestor: BI & Sistema ───

model GestorDashboard {
  id        String   @id @default(cuid())
  name      String
  sector    String
  config    Json?
  createdAt DateTime @default(now())
  widgets   DashboardWidget[]
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String
  widgetType  String
  title       String
  config      Json?
  order       Int      @default(0)
  dashboard   GestorDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
}

model SystemHealthCheck {
  id        String   @id @default(cuid())
  service   String
  status    String
  latencyMs Int?
  metadata  Json?
  checkedAt DateTime @default(now())
}

model SystemBackup {
  id        String   @id @default(cuid())
  type      String
  status    String
  sizeBytes Int?
  path      String?
  createdAt DateTime @default(now())
}

model SystemError {
  id        String   @id @default(cuid())
  service   String
  message   String
  stack     String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Plataforma: Governança, Workflows, SLA, Eventos ───

enum PersonaScope {
  CLIENT
  PARTNER
  NGO
  GESTOR
  GLOBAL
}

enum LgpdRequestType {
  EXPORT
  DELETE
  ANONYMIZE
  ACCESS
}

enum LgpdRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        String   // CLIENT, PARTNER, NGO, ECOPET
  parentId    String?
  parent      Organization? @relation("OrgHierarchy", fields: [parentId], references: [id])
  children    Organization[] @relation("OrgHierarchy")
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     OrganizationMember[]
  units       OrganizationUnit[]
  users       User[]
  featureOverrides FeatureFlagOverride[]
  workflows   WorkflowDefinition[]
  slaPolicies SlaPolicy[]
  businessRules BusinessRule[]
  costEntries CostEntry[]
  events      PlatformEvent[]
  lgpdRequests LgpdRequest[]
  retentionPolicies DataRetentionPolicy[]

  @@index([type])
  @@index([parentId])
}

model OrganizationUnit {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  type           String   // filial, departamento, nucleo, centro_custo
  parentId       String?
  parent         OrganizationUnit? @relation("UnitHierarchy", fields: [parentId], references: [id])
  children       OrganizationUnit[] @relation("UnitHierarchy")
  isActive       Boolean  @default(true)
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        OrganizationMember[]

  @@unique([organizationId, code])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  unitId         String?
  userId         String
  role           String   @default("member")
  isAdmin        Boolean  @default(false)
  joinedAt       DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit           OrganizationUnit? @relation(fields: [unitId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(100)
  personaScope PersonaScope @default(GLOBAL)
  moduleKey   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  overrides   FeatureFlagOverride[]
}

model FeatureFlagOverride {
  id             String   @id @default(cuid())
  flagId         String
  organizationId String?
  enabled        Boolean
  flag           FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([flagId, organizationId])
}

model WorkflowDefinition {
  id             String   @id @default(cuid())
  name           String
  description    String?
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  triggerType    String   // event, schedule, manual
  triggerConfig  Json
  actions        Json     // array of { type, config }
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  instances      WorkflowInstance[]

  @@index([personaScope, isActive])
}

model WorkflowInstance {
  id           String   @id @default(cuid())
  definitionId String
  ownerId      String?
  status       String   @default("RUNNING") // RUNNING, COMPLETED, FAILED, PAUSED
  triggerData  Json?
  result       Json?
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  owner        User?    @relation("WorkflowOwner", fields: [ownerId], references: [id])
  logs         WorkflowExecutionLog[]

  @@index([status, startedAt])
}

model WorkflowExecutionLog {
  id         String   @id @default(cuid())
  instanceId String
  step       String
  status     String
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model SlaPolicy {
  id             String   @id @default(cuid())
  name           String
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  entityType     String   // support_ticket, report, adoption, campaign, chat
  responseMins   Int
  resolutionMins Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  records        SlaRecord[]

  @@index([entityType, personaScope])
}

model SlaRecord {
  id           String   @id @default(cuid())
  policyId     String
  entityType   String
  entityId     String
  status       String   @default("ACTIVE") // ACTIVE, MET, BREACHED, CANCELLED
  dueAt        DateTime
  respondedAt  DateTime?
  resolvedAt   DateTime?
  breachedAt   DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  policy       SlaPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([status, dueAt])
}

model EntityVersion {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  version    Int
  snapshot   Json
  changeNote String?
  authorId   String?
  createdAt  DateTime @default(now())
  author     User?    @relation("VersionAuthor", fields: [authorId], references: [id])

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
}

model CostEntry {
  id             String   @id @default(cuid())
  category       String   // ia, api, email, whatsapp, storage, db, server, robot, integration
  moduleKey      String?
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  userId         String?
  amount         Float
  currency       String   @default("BRL")
  quantity       Float?
  unit           String?
  periodStart    DateTime
  periodEnd      DateTime
  metadata       Json?
  createdAt      DateTime @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@index([category, periodStart])
  @@index([organizationId])
}

model DataPipeline {
  id          String   @id @default(cuid())
  name        String
  layer       String   // lake, warehouse, mart, etl
  source      String
  destination String?
  schedule    String?
  status      String   @default("IDLE")
  lastRunAt   DateTime?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessRule {
  id             String   @id @default(cuid())
  name           String
  description    String?
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  condition      Json     // { field, operator, value }
  action         Json     // { type, params }
  priority       Int      @default(100)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  executions     RuleExecutionLog[]

  @@index([personaScope, isActive])
}

model RuleExecutionLog {
  id        String   @id @default(cuid())
  ruleId    String
  entityType String?
  entityId  String?
  result    String   // APPLIED, SKIPPED, ERROR
  metadata  Json?
  createdAt DateTime @default(now())
  rule      BusinessRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model PlatformEvent {
  id             String   @id @default(cuid())
  eventType      String
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  actorId        String?
  entityType     String?
  entityId       String?
  payload        Json?
  severity       String   @default("info")
  createdAt      DateTime @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  actor          User?    @relation("EventActor", fields: [actorId], references: [id])

  @@index([eventType, createdAt])
  @@index([personaScope, createdAt])
}

model EventSubscription {
  id          String   @id @default(cuid())
  name        String
  eventTypes  Json     // string[]
  channel     String   // webhook, email, robot, workflow
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  granted     Boolean
  version     String?
  ip          String?
  metadata    Json?
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
}

model LgpdRequest {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  type           LgpdRequestType
  status         LgpdRequestStatus @default(PENDING)
  notes          String?
  resultUrl      String?
  processedById  String?
  processedAt    DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, status])
}

model DataRetentionPolicy {
  id             String   @id @default(cuid())
  name           String
  dataCategory   String   // logs, messages, audit, documents
  retentionDays  Int
  archiveDays    Int?
  autoDelete     Boolean  @default(false)
  personaScope   PersonaScope @default(GLOBAL)
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model ObservabilitySnapshot {
  id          String   @id @default(cuid())
  service     String
  metricKey   String
  value       Float
  unit        String?
  status      String   @default("ok")
  metadata    Json?
  recordedAt  DateTime @default(now())

  @@index([service, metricKey, recordedAt])
}

model GovernanceInsight {
  id          String   @id @default(cuid())
  userId      String?
  category    String   // lgpd, compliance, risk, security, retention
  title       String
  description String
  severity    String   @default("info")
  suggestion  String?
  metadata    Json?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@index([category, resolved])
}

model BackupJob {
  id          String   @id @default(cuid())
  type        String   // auto, manual, snapshot
  scope       String   @default("full")
  status      String   @default("PENDING")
  sizeBytes   Int?
  path        String?
  initiatedBy String?
  restoredAt  DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([status, createdAt])
}

enum GuestChatStatus {
  GUEST
  AUTHENTICATED
  CONVERTED
  EXPIRED
}

model GuestChatSession {
  id              String          @id @default(cuid())
  guestId         String          @unique
  sessionId       String
  browserId       String?
  conversationId  String?         @unique
  convertedUserId String?
  status          GuestChatStatus @default(GUEST)
  messageCount    Int             @default(0)
  expiresAt       DateTime
  convertedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  messages        GuestMessage[]
  conversation    Conversation?   @relation(fields: [conversationId], references: [id])
  convertedUser   User?           @relation("GuestConvertedUser", fields: [convertedUserId], references: [id])

  @@index([status, expiresAt])
}

model GuestMessage {
  id        String           @id @default(cuid())
  sessionId String
  role      String
  content   String
  type      String           @default("TEXT")
  metadata  Json?
  createdAt DateTime         @default(now())
  session   GuestChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AIChatLog {
  id             String   @id @default(cuid())
  userId         String?
  guestSessionId String?
  conversationId String?
  prompt         String
  response       String
  model          String?
  metadata       Json?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([conversationId])
}

// ─── Feed Social (Etapa 11) ───────────────────────────────────────────────

enum SocialPostVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum SocialPostStatus {
  PUBLISHED
  HIDDEN
  REPORTED
  REMOVED
}

enum SocialCommentStatus {
  PUBLISHED
  HIDDEN
  REPORTED
  REMOVED
}

enum SocialMediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum SocialReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum SocialReportReason {
  SPAM
  HARASSMENT
  HATE
  VIOLENCE
  SEXUAL_CONTENT
  ANIMAL_ABUSE
  SCAM
  MISINFORMATION
  OTHER
}

enum PublicProfileVisibility {
  PUBLIC
  PRIVATE
}

model SocialPost {
  id                String               @id @default(cuid())
  authorId          String
  petId             String?
  content           String
  visibility        SocialPostVisibility @default(PUBLIC)
  status            SocialPostStatus     @default(PUBLISHED)
  locationText      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  editedAt          DateTime?
  deletedAt         DateTime?
  moderatedAt       DateTime?
  moderatedById     String?
  moderationReason  String?

  author            User                 @relation("SocialPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  pet               Pet?                 @relation(fields: [petId], references: [id], onDelete: SetNull)
  moderatedBy       User?                @relation("SocialPostModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  media             SocialPostMedia[]
  likes             SocialPostLike[]
  comments          SocialComment[]
  saves             SocialPostSave[]
  shares            SocialPostShare[]
  hashtags          SocialPostHashtag[]
  reports           SocialReport[]

  @@index([authorId])
  @@index([createdAt])
  @@index([status])
  @@index([visibility])
  @@index([petId])
}

model SocialPostMedia {
  id              String          @id @default(cuid())
  postId          String
  fileUrl         String
  fileName        String
  mimeType        String
  fileSize        Int
  mediaType       SocialMediaType
  storageProvider String
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  post            SocialPost      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model SocialPostLike {
  id        String     @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model SocialComment {
  id                String              @id @default(cuid())
  postId            String
  authorId          String
  parentCommentId   String?
  content           String
  status            SocialCommentStatus @default(PUBLISHED)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  editedAt          DateTime?
  deletedAt         DateTime?
  moderatedAt       DateTime?
  moderatedById     String?
  moderationReason  String?

  post              SocialPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author            User                @relation("SocialCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment     SocialComment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies           SocialComment[]     @relation("CommentReplies")
  moderatedBy       User?               @relation("SocialCommentModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  likes             SocialCommentLike[]
  reports           SocialReport[]

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
}

model SocialCommentLike {
  id        String        @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime      @default(now())
  comment   SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model SocialPostSave {
  id        String     @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model SocialPostShare {
  id                   String        @id @default(cuid())
  postId               String
  userId               String
  targetConversationId String?
  message              String?
  createdAt            DateTime      @default(now())
  post                 SocialPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetConversation   Conversation? @relation(fields: [targetConversationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([postId])
}

model SocialReport {
  id           String             @id @default(cuid())
  postId       String?
  commentId    String?
  reporterId   String
  reason       SocialReportReason
  description  String?
  status       SocialReportStatus @default(OPEN)
  reviewedById String?
  reviewedAt   DateTime?
  resolution   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  post         SocialPost?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment      SocialComment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)
  reporter     User               @relation("SocialReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy   User?              @relation("SocialReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([postId])
  @@index([commentId])
  @@index([reporterId])
}

model SocialPostHashtag {
  id        String     @id @default(cuid())
  postId    String
  hashtagId String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag    @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

model PublicProfile {
  id          String                  @id @default(cuid())
  userId      String                  @unique
  displayName String
  bio         String?
  avatarUrl   String?
  coverUrl    String?
  visibility  PublicProfileVisibility @default(PUBLIC)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserSocialBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())
  blocker   User     @relation("SocialBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("SocialBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum DataPrivacyRequestType {
  EXPORT
  DELETE_ACCOUNT
  RECTIFY
  REVOKE_CONSENT
}

enum DataPrivacyRequestStatus {
  OPEN
  IN_REVIEW
  COMPLETED
  REJECTED
}

model DataPrivacyRequest {
  id            String                   @id @default(cuid())
  userId        String
  type          DataPrivacyRequestType
  status        DataPrivacyRequestStatus @default(OPEN)
  description   String?
  requestedAt   DateTime                 @default(now())
  processedAt   DateTime?
  processedById String?
  resolution    String?
  metadata      Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  user        User  @relation("PrivacyRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  processedBy User? @relation("PrivacyRequestProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, requestedAt])
  @@index([type])
}
