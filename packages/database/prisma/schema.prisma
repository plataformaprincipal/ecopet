  actorId     String?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  partner     User     @relation("PartnerInventoryLogs", fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([partnerId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String?
