  updatedAt DateTime   @updatedAt

  @@index([sessionId])
}

model CartItem {
  id                String  @id @default(cuid())
  cartId            String
  productId         String
  quantity          Int     @default(1)
  unitPriceSnapshot Float?
  cart              Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Product @relation(fields: [productId], references: [id])
  @@unique([cartId, productId])
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       Int            @unique
  userId            String
  partnerId         String?
  status            OrderStatus    @default(PENDING)
  fulfillmentStatus OrderStatus    @default(PENDING)
  total             Float
  shippingCost      Float            @default(0)
  discount          Float            @default(0)
  shippingAddress   Json
  alternateAddress  Json?
  deliveryMethod    DeliveryMethod @default(DELIVERY_LOCAL)
  paymentMethod     PaymentMethod  @default(PIX)
  scheduledAt       DateTime?
  deliveryNotes     String?
  pickupInstructions String?
  pickupQrCode      String?
  thirdPartyPickup  Json?
  serviceMode       ServiceFulfillmentMode?
  onlineLink        String?
  carrierName       String?
  stripePaymentId   String?
  walletTransactionId String?
  trackingCode      String?
  estimatedDelivery DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User           @relation("BuyerOrders", fields: [userId], references: [id])
  partner           User?          @relation("PartnerOrders", fields: [partnerId], references: [id])
  items             OrderItem[]
  fulfillments      OrderFulfillment[]
  statusHistory     OrderStatusHistory[]
  refunds           Refund[]
  payments          Payment[]

  @@index([userId])
  @@index([partnerId])
  @@index([status])
}

model OrderFulfillment {
