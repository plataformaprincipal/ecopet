enum RobotDomain {
  HEALTH
  FINANCE
  AGENDA
  LEISURE
  SHOPPING
  PETS
  INTEGRATIONS
  COMMERCIAL
  STOCK
  PRODUCTION
  MARKETING
  QUALITY
  LOGISTICS
