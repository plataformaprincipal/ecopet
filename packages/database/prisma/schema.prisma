}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  type        WalletTransactionType
  amount      Float
  balanceAfter Float
  description String?
  orderId     String?
  refundId    String?
  metadata    Json?
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model WalletLog {
  id        String   @id @default(cuid())
  walletId  String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Refund {
  id              String            @id @default(cuid())
  userId          String
  orderId         String?
  originalMethod  PaymentMethod
  destination     RefundDestination
  amount          Float
  status          RefundStatus      @default(PENDING)
  reason          String?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  user            User              @relation(fields: [userId], references: [id])
  order           Order?            @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([orderId])
}

model Cashback {
  id          String   @id @default(cuid())
  userId      String
  orderId     String?
  amount      Float
  percentage  Float?
  description String?
  expiresAt   DateTime?
  applied     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ─── Logística de Parceiros ───

model PartnerLogisticsConfig {
  id                    String   @id @default(cuid())
  partnerId             String   @unique
  pickupEnabled         Boolean  @default(true)
  deliveryLocal         Boolean  @default(true)
  deliveryRegional      Boolean  @default(false)
  deliveryNational      Boolean  @default(false)
  deliveryOwn           Boolean  @default(true)
  deliveryPartnerLogistics Boolean @default(false)
  scheduledPickup       Boolean  @default(true)
  scheduledDelivery     Boolean  @default(true)
  pickupAddress         Json?
  pickupHours           String?
  pickupInstructions    String?
  pickupResponsible     String?
  localDeliveryDays     Int      @default(3)
  regionalDeliveryDays  Int      @default(7)
  nationalDeliveryDays  Int      @default(15)
  localDeliveryFee      Float    @default(0)
  regionalDeliveryFee   Float    @default(15)
  nationalDeliveryFee   Float    @default(35)
  carrierPartners       Json?
