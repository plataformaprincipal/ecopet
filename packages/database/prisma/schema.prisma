  resolvedAt   DateTime?
  closedAt     DateTime?
  requester    User              @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee     User?             @relation("TicketAssignee", fields: [assigneeId], references: [id])
  conversation Conversation?

  @@index([status, priority])
  @@index([status])
  @@index([requesterId])
}

model ContentReport {
  id           String       @id @default(cuid())
  reporterId   String
  targetType   String
  targetId     String
  reason       String
  description  String?
  status       ReportStatus @default(PENDING)
  action       String?
  aiFlags      Json?
  reviewerId   String?
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?
  reporter     User         @relation("ReportAuthor", fields: [reporterId], references: [id])
  reviewer     User?        @relation("ReportReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model CustomQuote {
  id             String      @id @default(cuid())
  conversationId String?
  requesterId    String
  providerId     String
  name           String
  description    String
  value          Float
  validUntil     DateTime
  executionDays  Int?
  status         QuoteStatus @default(DRAFT)
  includedItems  Json?
  excludedItems  Json?
  conditions     String?
  version        Int         @default(1)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  requester      User        @relation("QuoteRequester", fields: [requesterId], references: [id])
  provider       User        @relation("QuoteProvider", fields: [providerId], references: [id])

  @@index([status])
  @@index([requesterId, providerId])
}

