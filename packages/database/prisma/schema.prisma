// ─── Autenticação & Segurança ───

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  device     String?
  ip         String?
  userAgent  String?
  active     Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  username  String?
  success   Boolean
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  severity  String   @default("info")
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  purpose   String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, used])
}

model SystemBootstrap {
  id                  String    @id @default("singleton")
  bootstrapUsername   String    @default("gestorveras")
  bootstrapUserId     String?
  bootstrapUsed       Boolean   @default(false)
  bootstrapUsedAt     DateTime?
  bootstrapDisabled   Boolean   @default(false)
  masterAdminCreated  Boolean   @default(false)
  masterAdminUserId   String?
  initializedAt       DateTime?
  updatedAt           DateTime  @updatedAt
}

model GestorInvite {
  id           String   @id @default(cuid())
  email        String
  name         String
  roleCode     String
  departmentId String?
  tempPassword String?
  token        String   @unique
  status       String   @default("PENDING")
  invitedById  String
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())
  invitedBy    User     @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([email, status])
}

model AuditRiskFlag {
  id         String   @id @default(cuid())
  auditLogId String
  flagType   String
  severity   String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
}

