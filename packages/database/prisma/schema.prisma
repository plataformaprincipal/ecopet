  HR
  AGROPET
  AI
  CAMPAIGNS
  DONATIONS
  RESCUE
  PROJECTS
  VOLUNTEERS
  EVENTS
  MONITORING
  AUDIT
  MODERATION
  SECURITY
  GROWTH
}

enum DeliveryMethod {
  PICKUP_LOCAL
  DELIVERY_LOCAL
  DELIVERY_REGIONAL
  DELIVERY_NATIONAL
  DELIVERY_OWN
  DELIVERY_PARTNER_LOGISTICS
  DELIVERY_SCHEDULED
  PICKUP_SCHEDULED
}

enum PaymentMethod {
  CARD
  PIX
  CASH
  TRANSFER
  WALLET
  BOLETO
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  CASHBACK
  BONUS
  CAMPAIGN
  DONATION
  TRANSFER_IN
  TRANSFER_OUT
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RefundDestination {
  CARD
  WALLET
}

enum ServiceFulfillmentMode {
  IN_PERSON
  HOME
  ONLINE
}

enum AdvisoryPlanType {
  PARTNER_BUSINESS
  NGO_SOCIAL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  passwordHash  String
  name          String
  cpf           String?   @unique
  cnpj          String?   @unique
  birthDate     DateTime?
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  avatar        String?
  avatarUrl     String?
  gender        String?
  role          UserRole  @default(TUTOR)
  accountStatus AccountStatus @default(ACTIVE)
  accountStatusReason String?
  bio           String?
  isVerified    Boolean   @default(false)
  isPremium     Boolean   @default(false)
  isOrgAdmin    Boolean   @default(false)
  isBootstrapUser Boolean @default(false)
  isMasterAdmin Boolean   @default(false)
  firstLoginRequired Boolean @default(false)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  passwordChangedAt DateTime?
  badges        Json?
  socialLinks   Json?
  preferences   Json?
  documents     Json?
  termsAcceptedAt DateTime?
  lgpdAcceptedAt  DateTime?
  latitude      Float?
  longitude     Float?
  darkMode      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addressRecord Address?
  pets          Pet[]
  ongPets       Pet[]     @relation("PetOng")
  protectorPets Pet[]     @relation("PetProtector")
  petEventsAuthored PetEvent[] @relation("PetEventAuthor")
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  savedPosts    SavedPost[]
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Follower")
  notifications Notification[]
  sentMessages  Message[] @relation("Sender")
  conversations ConversationParticipant[]
  createdConversations Conversation[] @relation("ConversationCreator")
  messageReactions MessageReaction[] @relation("MessageReactions")
  messageReportsFiled MessageReport[] @relation("MessageReportsFiled")
  messageReportsReviewed MessageReport[] @relation("MessageReportsReviewed")
  blocksInitiated UserBlock[] @relation("UserBlocksInitiated")
  blocksReceived UserBlock[] @relation("UserBlocksReceived")
  orders        Order[]   @relation("BuyerOrders")
  partnerOrders Order[]   @relation("PartnerOrders")
  wallet        Wallet?
  refunds       Refund[]
  advisorySubscription AdvisorySubscription?
  partnerLogistics PartnerLogisticsConfig? @relation("PartnerLogistics")
  cart          Cart?
  favorites     Favorite[]
  subscriptions Subscription[]
  veterinarianProfile VeterinarianProfile?
  clinicProfile       ClinicProfile?
  petshopProfile      PetshopProfile?
  ongProfile          OngProfile?
  partnerProfile      PartnerProfile?
  tutorProfile        TutorProfile?
  sellerProfile       SellerProfile?
  serviceProviderProfile ServiceProviderProfile?
  adminProfile        AdminProfile?
  gestorProfile       GestorProfile?
  products            Product[] @relation("SellerProducts")
  services            Service[] @relation("ProviderServices")
  customServiceRequests CustomServiceRequest[] @relation("TutorRequests")
  reviews             Review[]
  serviceReviews      ServiceReview[]
  partnerServiceReviews ServiceReview[] @relation("PartnerServiceReviews")
  inventoryLogs       InventoryLog[] @relation("PartnerInventoryLogs")
  adoptionListings    AdoptionListing[]
  medicalRecords      MedicalRecord[] @relation("RecordAuthor")
  aiSessions          AiSession[]
  gamification        GamificationProfile?
  rbacAssignments     UserRbacAssignment[]
  auditLogs           AuditLog[] @relation("AuditActor")
  approvalRequests    ApprovalRequest[] @relation("ApprovalRequester")
  approvalReviews     ApprovalRequest[] @relation("ApprovalReviewer")
  supportTickets      SupportTicket[] @relation("TicketRequester")
  assignedTickets     SupportTicket[] @relation("TicketAssignee")
  contentReports      ContentReport[] @relation("ReportAuthor")
  reviewedReports     ContentReport[] @relation("ReportReviewer")
  socialPostsAuthored SocialPost[] @relation("SocialPostAuthor")
  socialPostsModerated SocialPost[] @relation("SocialPostModerator")
  socialCommentsAuthored SocialComment[] @relation("SocialCommentAuthor")
  socialCommentsModerated SocialComment[] @relation("SocialCommentModerator")
  socialPostLikes     SocialPostLike[]
  socialCommentLikes  SocialCommentLike[]
  socialPostSaves     SocialPostSave[]
  socialPostShares    SocialPostShare[]
  socialReportsFiled  SocialReport[] @relation("SocialReportReporter")
  socialReportsReviewed SocialReport[] @relation("SocialReportReviewer")
  publicSocialProfile PublicProfile?
  userFollowsAsFollower UserFollow[] @relation("UserFollower")
  userFollowsAsFollowing UserFollow[] @relation("UserFollowing")
  socialBlocksInitiated UserSocialBlock[] @relation("SocialBlocker")
  socialBlocksReceived UserSocialBlock[] @relation("SocialBlockBlocked")
  integrations        Integration[]
  operationalRobots   OperationalRobot[]
  customQuotesSent    CustomQuote[] @relation("QuoteRequester")
  customQuotesReceived CustomQuote[] @relation("QuoteProvider")
  privacyRequests      DataPrivacyRequest[] @relation("PrivacyRequestUser")
  privacyRequestsProcessed DataPrivacyRequest[] @relation("PrivacyRequestProcessor")
  department          Department? @relation(fields: [departmentId], references: [id])
  departmentId        String?
  sessions            UserSession[]
  loginLogs           LoginLog[]
  passwordResetTokens PasswordResetToken[]
  securityEvents      SecurityEvent[]
  gestorInvitesSent   GestorInvite[] @relation("InviteSender")
  platformDocuments   PlatformDocument[]
  verificationCodes   VerificationCode[]
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  organizationUnits   OrganizationMember[]
  consentRecords      ConsentRecord[]
  lgpdRequests        LgpdRequest[]
  platformEvents      PlatformEvent[] @relation("EventActor")
  workflowInstances   WorkflowInstance[] @relation("WorkflowOwner")
  costEntries         CostEntry[]
  entityVersions      EntityVersion[] @relation("VersionAuthor")
  governanceInsights  GovernanceInsight[]
  appointments        Appointment[]
  partnerAppointments Appointment[] @relation("PartnerAppointments")
  petDocumentsOwned   PetDocument[]
  aiChatLogs          AIChatLog[]
  convertedGuestChats GuestChatSession[] @relation("GuestConvertedUser")
  iotDevices          IotDevice[]
  agroUnits           AgroUnit[]

  @@index([email])
  @@index([username])
  @@index([phone])
  @@index([role])
  @@index([organizationId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String  @unique
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  country    String  @default("BR")
  latitude   Float?
  longitude  Float?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pet {
  id                String     @id @default(cuid())
  ownerId           String
  ongId             String?
  protectorId       String?
  name              String
  photo             String?
  photos            Json?
  species           PetSpecies
  breed             String?
  size              PetSize?
  sex               String?
  birthDate         DateTime?
  weight            Float?
  color             String?
  neutered          Boolean    @default(false)
  hasMicrochip      Boolean    @default(false)
  microchip         String?
  behavior          String?
  temperament       String?
  rescueHistory     String?
  specialNeeds      String?
  dietaryRestriction String?
  allergiesText     String?
  diet              String?
  activityLevel     String?
  notes             String?
  documents         Json?
  qrCodeSlug        String?    @unique
  publicProfile     Boolean    @default(false)
  locationAddress   String?
  locationCity      String?
  locationState     String?
  isLost            Boolean    @default(false)
  lostAt            DateTime?
  lostCity          String?
  lostContact       String?
  availableForAdoption Boolean @default(false)
  adoptionReason    String?
  adoptionRequirements String?
  adoptionCity      String?
  adoptionFee       Float?
  aiProfile         Json?
  deletedAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  owner             User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ong               User?      @relation("PetOng", fields: [ongId], references: [id], onDelete: SetNull)
  protector         User?      @relation("PetProtector", fields: [protectorId], references: [id], onDelete: SetNull)
  vaccinations      Vaccination[]
  medications       Medication[]
  allergies         Allergy[]
  exams             Exam[]
  consultations     Consultation[]
  medicalRecords    MedicalRecord[]
  weightRecords     PetWeightRecord[]
  media             PetMedia[]
  events            PetEvent[]
  posts             Post[]
  socialPosts       SocialPost[]
  appointments      Appointment[]
  iotDevices        IotDevice[]
  reminders         PetReminder[]
  petDocuments      PetDocument[]

  @@index([ownerId])
  @@index([ongId])
  @@index([isLost])
  @@index([availableForAdoption])
  @@index([deletedAt])
}

model PetWeightRecord {
  id         String   @id @default(cuid())
  petId      String
  weight     Float
  recordedAt DateTime @default(now())
  notes      String?
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, recordedAt])
}

model PetMedia {
  id         String   @id @default(cuid())
  petId      String
  type       String
  url        String
  caption    String?
  recordedAt DateTime @default(now())
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model PetEvent {
  id          String   @id @default(cuid())
  petId       String
  eventType   String
  title       String
  description String?
  metadata    Json?
  createdById String?
  createdAt   DateTime @default(now())
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("PetEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([petId, createdAt])
}

model Vaccination {
  id           String   @id @default(cuid())
  petId        String
  name         String
  manufacturer String?
  batch        String?
  date         DateTime
  nextDue      DateTime?
  veterinarian String?
  notes        String?
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Medication {
  id        String   @id @default(cuid())
  petId     String
  name      String
  dosage    String?
  frequency String?
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Allergy {
  id       String  @id @default(cuid())
  petId    String
  allergen String
  severity String?
  notes    String?
  pet      Pet     @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model PetReminder {
  id          String         @id @default(cuid())
  petId       String
  type        String
  title       String
  description String?
  dueAt       DateTime
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  pet         Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, dueAt])
  @@index([status])
}

model PetDocument {
  id           String    @id @default(cuid())
  petId        String
  ownerId      String
  type         String
  name         String
  description  String?
  documentDate DateTime?
  url          String?
  mimeType     String?
  sizeBytes    Int?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pet          Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([ownerId])
  @@index([deletedAt])
}

model PartnerAvailability {
  id              String         @id @default(cuid())
  partnerId       String
  weekday         Int
  startTime       String
  endTime         String
  intervalMinutes Int            @default(30)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  partner         PartnerProfile @relation(fields: [partnerId], references: [userId], onDelete: Cascade)

  @@index([partnerId, weekday])
}

model PartnerBlockedSlot {
  id        String         @id @default(cuid())
  partnerId String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  partner   PartnerProfile @relation(fields: [partnerId], references: [userId], onDelete: Cascade)

  @@index([partnerId, startAt])
}

model Exam {
  id        String   @id @default(cuid())
  petId     String
  type      String
  date      DateTime
  result    String?
  fileUrl   String?
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Consultation {
  id            String   @id @default(cuid())
  petId         String
  veterinarianId String?
  date          DateTime
  type          String
  notes         String?
  prescription  String?
  pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Appointment {
  id               String                   @id @default(cuid())
  userId           String
  petId            String
  partnerId        String?
  serviceId        String?
  serviceType      AppointmentServiceType
  attendanceMode   AppointmentAttendanceMode
  scheduledDate    DateTime
  scheduledTime    String
  scheduledAt      DateTime
  endAt            DateTime?
  observations     String?
  status           AppointmentStatus        @default(PENDING)
  cancelledAt      DateTime?
  cancelReason     String?
  completedAt      DateTime?
  rescheduledFromId String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet              Pet                      @relation(fields: [petId], references: [id], onDelete: Cascade)
  partner          User?                    @relation("PartnerAppointments", fields: [partnerId], references: [id], onDelete: SetNull)
  service          Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceReview    ServiceReview?
  rescheduledFrom  Appointment?             @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo    Appointment[]            @relation("AppointmentReschedule")

  @@index([userId, status])
  @@index([partnerId, status])
  @@index([petId])
  @@index([scheduledAt])
  @@index([serviceId])
}

model MedicalRecord {
  id               String   @id @default(cuid())
  petId            String
  authorId         String
  type             String
  title            String
  content          String?
  recordDate       DateTime @default(now())
  veterinarianName String?
  clinicName       String?
  fileUrl          String?
  attachments      Json?
  createdAt        DateTime @default(now())
  pet              Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  author           User     @relation("RecordAuthor", fields: [authorId], references: [id])
}

model TutorProfile {
  id                String @id @default(cuid())
  userId            String @unique
  petCount          Int?
  primaryInterests  Json?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VeterinarianProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  crmv                  String   @unique
  crmvState             String?
  specialties           Json?
  description           String?
  certificates          Json?
  experience            Int?
  averageConsultationPrice Float?
  onlineAvailable       Boolean  @default(true)
  inPersonAvailable     Boolean  @default(true)
  professionalAddress   String?
  documents             Json?
  schedule              Json?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClinicProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tradeName            String
  cnpj                 String   @unique
  technicalResponsible String?
  responsibleCrmv      String?
  photos               Json?
  services             Json?
  emergency            Boolean  @default(false)
  team                 Json?
  hours                Json?
  documents            Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PetshopProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tradeName      String
  cnpj           String   @unique
  responsible    String?
  banner         String?
  photos         Json?
  sellsProducts  Boolean  @default(true)
  offersServices Boolean  @default(false)
  categories     Json?
  delivery       Boolean  @default(true)
  pickup         Boolean  @default(true)
  hours          Json?
  documents      Json?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id                String @id @default(cuid())
  userId            String @unique
  tradeName         String
  cnpj              String @unique
  responsible       String
  productCategories Json?
  deliveryPolicy    String?
  exchangePolicy    String?
  bankData          Json?
  documents         Json?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceProviderProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  documentType   String
  documentNumber String  @unique
  serviceTypes   Json
  serviceArea    String?
  homeService    Boolean @default(false)
  startingPrice  Float?
  availability   String?
  documents      Json?
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OngProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  ongName            String?
  name               String
  tradeName          String?
  documentType       String?
  cnpj               String             @unique
  responsible        String
  responsibleName    String?
  institutionalEmail String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  description        String?
  focusArea          String?
  verificationStatus VerificationStatus @default(PENDING)
  photos             Json?
  requirements       String?
  actionTypes        Json?
  animalCapacity     Int?
  acceptsDonations   Boolean            @default(true)
  documents          Json?
  profileDetails     Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PartnerProfile {
