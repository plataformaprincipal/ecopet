generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  TUTOR
  VETERINARIAN
  CLINIC
  PETSHOP
  SELLER
  SERVICE_PROVIDER
  ONG
  ADMIN
  GESTOR
  DELIVERY
  INFLUENCER
  PARTNER
}

enum AccountStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum PetSpecies {
  DOG
  CAT
  BIRD
  RODENT
  REPTILE
  FISH
  OTHER
}

enum PetSize {
  MINI
  SMALL
  MEDIUM
  LARGE
  GIANT
}

