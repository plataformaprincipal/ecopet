model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  members     User[]
  gestors     GestorProfile[]
  rbacRoles   RbacRole[]
}

model Permission {
  id          String   @id @default(cuid())
  module      String
  resource    String
  action      String
  code        String   @unique
  description String?
  roles       RolePermission[]
}

model RbacRole {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  hierarchyLevel Int      @default(1)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  permissions    RolePermission[]
  assignments    UserRbacAssignment[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         RbacRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserRbacAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedBy String?
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      RbacRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId, roleId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  module     String
  resource   String
  resourceId String?
  profile    String?
  entityBefore Json?
  entityAfter  Json?
  riskLevel  String?
  status     String?
  observation String?
  location   String?
  metadata   Json?
  ip         String?
  userAgent  String?
