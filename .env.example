# ─── EcoPet Foundation (apps/web) ───

# PostgreSQL — obrigatório para cadastro/login
DATABASE_URL="postgresql://ecopet:ecopet_dev@localhost:5432/ecopet?schema=public"

# Cookie de sessão (JWT assinado, HTTP-only)
AUTH_SECRET=change-me-in-production-auth-secret

# Next.js
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-nextauth

# URL pública da aplicação (links de e-mail)
APP_URL=http://localhost:3000

# ─── E-mail transacional (SMTP universal) ───
# Provedor automático (opcional): gmail | outlook | hotmail | live | microsoft365 |
# zoho | hostinger | locaweb | kinghost | uolhost | ses | sendgrid | mailgun | brevo | resend | custom
MAIL_PROVIDER=gmail

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# Remetente (use SMTP_FROM legado OU par nome/e-mail)
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=seu-email@gmail.com
# SMTP_FROM="EcoPet <seu-email@gmail.com>"

# Pool e timeout (opcional)
# SMTP_POOL=true
# SMTP_MAX_CONNECTIONS=5
# SMTP_MAX_MESSAGES=100
# SMTP_TIMEOUT=30000

# Retentativas em ms (padrão dev: 0,2000,5000 | prod: 0,60000,300000)
# MAIL_RETRY_DELAYS_MS=0,60000,300000

# Destinatário para npm run test:mail
TEST_EMAIL=

# Nunca versione o arquivo .env real (contém SMTP_PASS).

# Opcional — API legada do monorepo (não necessária para fundação MVP)
# API_INTERNAL_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=
