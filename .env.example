# ─── EcoPet — Variáveis de Ambiente ───
# Copie para .env na raiz do monorepo. Nunca versione valores reais.

# ═══════════════════════════════════════════════════════════
# BANCO DE DADOS (obrigatório para auth/cadastro)
# ═══════════════════════════════════════════════════════════
# Docker (npm run db:up): senha ecopet_dev_password
# Embedded (node scripts/ensure-postgres.mjs): senha ecopet_dev
DATABASE_URL="postgresql://ecopet:ecopet_dev_password@localhost:5432/ecopet?schema=public"
DIRECT_URL="postgresql://ecopet:ecopet_dev_password@localhost:5432/ecopet?schema=public"

# Bootstrap do primeiro ADMIN (npm run admin:bootstrap)
# ECOPET_BOOTSTRAP_ADMIN_EMAIL=
# ECOPET_BOOTSTRAP_ADMIN_PASSWORD=
# ECOPET_BOOTSTRAP_ADMIN_NAME=
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# AUTENTICAÇÃO — apps/api
# ═══════════════════════════════════════════════════════════
JWT_SECRET=change-me-in-production-jwt-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_DAYS=7

# ═══════════════════════════════════════════════════════════
# API / PROXY
# ═══════════════════════════════════════════════════════════
API_INTERNAL_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=                    # URL pública da API (opcional)
API_PORT=4000
WEB_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# E-MAIL TRANSACIONAL (SMTP)
# ═══════════════════════════════════════════════════════════
MAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=seu-email@gmail.com
TEST_EMAIL=

# ═══════════════════════════════════════════════════════════
# INTEGRAÇÕES OPCIONAIS (produção — não obrigatórias em dev)
# ═══════════════════════════════════════════════════════════
# RESEND_API_KEY=
# OPENAI_API_KEY=
# AI_ENABLED=false
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_WEBHOOK_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# UPLOAD_DEV_FALLBACK=1                    # fallback local em dev (0 desliga)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# PAYMENT_PROVIDER=MERCADO_PAGO            # MERCADO_PAGO | PAGARME | STRIPE
# PAGARME_API_KEY=
# STRIPE_SECRET_KEY=
# MAPBOX_ACCESS_TOKEN=
# MELHOR_ENVIO_TOKEN=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════
# AMBIENTE
# ═══════════════════════════════════════════════════════════
NODE_ENV=development
# ECOPET_PROXY_LOG=1                      # logs do proxy /api/ecopet em dev

# ─── Segurança ───
# Em produção, JWT_SECRET, AUTH_SECRET e NEXTAUTH_SECRET são obrigatórios.
# O sistema falha na inicialização se ausentes (lib/env.ts).
