# ─── EcoPet — Variáveis de Ambiente ───
# Copie para .env na raiz do monorepo. Nunca versione valores reais.

# ═══════════════════════════════════════════════════════════
# BANCO DE DADOS — Supabase PostgreSQL
# ═══════════════════════════════════════════════════════════
# Transaction pooler (6543) — uso em runtime (Prisma / app)
DATABASE_URL="postgresql://postgres.rzzchclcvbhyuchshshn:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (5432) — migrations (prisma migrate)
DIRECT_URL="postgresql://postgres.rzzchclcvbhyuchshshn:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
# Local Docker alternativo: npm run db:up
# DATABASE_URL="postgresql://ecopet:ecopet_dev_password@localhost:5432/ecopet?schema=public"
# DIRECT_URL="postgresql://ecopet:ecopet_dev_password@localhost:5432/ecopet?schema=public"

# Bootstrap do primeiro ADMIN (npm run admin:bootstrap)
# ECOPET_BOOTSTRAP_ADMIN_EMAIL=
# ECOPET_BOOTSTRAP_ADMIN_PASSWORD=
# ECOPET_BOOTSTRAP_ADMIN_NAME=
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# AUTENTICAÇÃO — apps/api
# ═══════════════════════════════════════════════════════════
JWT_SECRET=change-me-in-production-jwt-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_DAYS=7

# ═══════════════════════════════════════════════════════════
# API / PROXY
# ═══════════════════════════════════════════════════════════
API_INTERNAL_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=                    # URL pública da API (opcional)
API_PORT=4000
WEB_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# E-MAIL TRANSACIONAL
# ═══════════════════════════════════════════════════════════
# O envio usa a cadeia multi-provedor: Resend → SendGrid → Brevo → SMTP.
# Em produção configure PELO MENOS UM provedor; sem nenhum, e-mails não são
# enviados (em dev caem no console; em prod retornam falha sem quebrar o fluxo).
# Recuperação de senha (OTP) usa exclusivamente Resend.
#
# --- Opção A: Resend (recomendado p/ deploy serverless) ---
# RESEND_API_KEY=
# EMAIL_FROM=no-reply@seudominio.com        # remetente verificado no provedor
# --- Opção B: SendGrid / Brevo ---
# SENDGRID_API_KEY=
# BREVO_API_KEY=
# --- Opção C: SMTP (nodemailer) ---
MAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=seu-email@gmail.com
TEST_EMAIL=

# ═══════════════════════════════════════════════════════════
# INTEGRAÇÕES OPCIONAIS (produção — não obrigatórias em dev)
# ═══════════════════════════════════════════════════════════
# Recuperação de senha (exclusivamente Resend — sem SMTP)
# RESEND_API_KEY=
# EMAIL_FROM=onboarding@resend.dev
# OPENAI_API_KEY=
# AI_ENABLED=false
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_WEBHOOK_SECRET=
# --- Cloudinary (upload de mídia em produção) ---
# Obrigatórias em produção. O upload é DIRETO navegador → Cloudinary,
# assinado pelo backend em /api/uploads/cloudinary/signature.
# O CLOUDINARY_API_SECRET nunca é exposto no frontend.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# UPLOAD_DEV_FALLBACK=1                    # fallback local SOMENTE em dev (0 desliga)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# PAYMENT_PROVIDER=MERCADO_PAGO            # MERCADO_PAGO | PAGARME | STRIPE
# PAGARME_API_KEY=
# STRIPE_SECRET_KEY=
# MAPBOX_ACCESS_TOKEN=
# MELHOR_ENVIO_TOKEN=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════
# OBSERVABILIDADE (opcional)
# ═══════════════════════════════════════════════════════════
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ═══════════════════════════════════════════════════════════
# AMBIENTE
# ═══════════════════════════════════════════════════════════
NODE_ENV=development
# ECOPET_PROXY_LOG=1                      # logs do proxy /api/ecopet em dev
# RATE_LIMIT_FORCE=1                      # força rate limit também em dev
# AUTH_RATE_LIMIT_RELAXED=1              # afrouxa limite de auth (testes)

# ─── Segurança / fail-fast em produção ───
# apps/web falha ao iniciar (runtime) se faltar: DATABASE_URL, AUTH_SECRET, NEXTAUTH_SECRET.
# apps/api falha ao iniciar se faltar: JWT_SECRET, DATABASE_URL, WEB_URL.
# Cookies de sessão são httpOnly + sameSite=lax + secure (apenas em produção).

# ─── TalkJS (mensagens — apps/web) ───
NEXT_PUBLIC_TALKJS_APP_ID=
TALKJS_SECRET_KEY=
