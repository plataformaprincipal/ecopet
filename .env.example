# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  ANTES DO DEPLOY VERCEL — confira seu .env local
# ═══════════════════════════════════════════════════════════════════════════════
# Se ainda estiver com valores abaixo, ALTERE na Vercel (não copie localhost):
#   NEXTAUTH_URL, APP_URL, NEXT_PUBLIC_APP_URL → https://SEU-DOMINIO.vercel.app
# Se AUTH_SECRET/NEXTAUTH_SECRET = "change-me-in-production...",
#   gere segredos reais: openssl rand -base64 32 (use o MESMO valor nos dois)
# RESEND_API_KEY deve ser chave REAL (re_...), não placeholder re_xxxxxxxxx
# CLOUDINARY_* são obrigatórios para upload em produção (não use UPLOAD_DEV_FALLBACK)
# NÃO cadastre na Vercel: API_INTERNAL_URL, UPLOAD_DEV_FALLBACK=1, NODE_ENV
# ═══════════════════════════════════════════════════════════════════════════════
#
# COPIE este arquivo para `.env` na RAIZ do monorepo para desenvolvimento local.
# NUNCA versione `.env` com valores reais.
#
# ─── DEPLOY VERCEL (apps/web) ─────────────────────────────────────────────────
# No painel Vercel → Settings → Environment Variables → Production:
#   1. Copie TODAS as variáveis da seção "OBRIGATÓRIAS — VERCEL" abaixo
#   2. Copie as "RECOMENDADAS" para login + cadastro + upload + e-mail completos
#   3. Use a MESMA URL HTTPS em NEXTAUTH_URL, APP_URL e NEXT_PUBLIC_APP_URL
#   4. NÃO use localhost em Production
#   5. Rode migrations antes/depois: npm run db:migrate:deploy (com DIRECT_URL)
#
# Catálogo programático: apps/web/src/lib/env-registry.ts
# Validação em produção: apps/web/src/lib/validate-production-env.ts
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# OBRIGATÓRIAS — VERCEL (Production + Preview)
# Sem estas variáveis login/cadastro NÃO funcionam.
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase PostgreSQL — pooler :6543 (runtime Prisma)
# Usada em: packages/database/prisma/schema.prisma, packages/database/src/client.ts
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta :5432 — APENAS migrations (prisma migrate deploy) e CI
# Não é usada em runtime serverless, mas deve existir no CI/local
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Segredo JWT do cookie ecopet-session (middleware Edge + /api/auth/*)
# Gere com: openssl rand -base64 32
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars

# Fallback NextAuth — pode ser IGUAL a AUTH_SECRET ou omitido se AUTH_SECRET existir
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars

# URL pública HTTPS — NÃO use localhost na Vercel
# Exemplo: https://ecopet-web.vercel.app ou https://seudominio.com
NEXTAUTH_URL=https://ecopet-web.vercel.app
APP_URL=https://ecopet-web.vercel.app
NEXT_PUBLIC_APP_URL=https://ecopet-web.vercel.app


# ═══════════════════════════════════════════════════════════════════════════════
# RECOMENDADAS — VERCEL (funcionalidades principais)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── E-mail / recuperação de senha (OTP via Resend) ───
# Pelo menos UM provedor: Resend (recomendado) OU SMTP completo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@seudominio.com

# ─── Cloudinary (upload de mídia em produção) ───
# Obrigatório para upload; sem isso cadastros com foto falham em produção
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════════════════════
# DESENVOLVIMENTO LOCAL — substitua os valores de produção acima por:
# ═══════════════════════════════════════════════════════════════════════════════
# NEXTAUTH_URL=http://localhost:3000
# APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# UPLOAD_DEV_FALLBACK=1
# NODE_ENV=development


# ═══════════════════════════════════════════════════════════════════════════════
# API EXPRESS (apps/api) — só se você deployar a API separadamente
# NÃO necessárias na Vercel se apenas apps/web estiver deployado
# ═══════════════════════════════════════════════════════════════════════════════
JWT_SECRET=change-me-in-production-jwt-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_DAYS=7
WEB_URL=http://localhost:3000
API_PORT=4000

# Proxy Next.js → API Express (/api/ecopet/*) — opcional
API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=


# ═══════════════════════════════════════════════════════════════════════════════
# E-MAIL ALTERNATIVO (se não usar Resend)
# ═══════════════════════════════════════════════════════════════════════════════
MAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM_NAME=EcoPet
SMTP_FROM_EMAIL=seu-email@gmail.com
# SMTP_FROM=EcoPet <seu-email@gmail.com>   # legado
# SENDGRID_API_KEY=
# BREVO_API_KEY=
# RESEND_FROM=onboarding@resend.dev        # legado


# ═══════════════════════════════════════════════════════════════════════════════
# SMS / recuperação por telefone (opcional)
# ═══════════════════════════════════════════════════════════════════════════════
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PHONE_SMS_RECOVERY_ENABLED=0
# ZENVIA_API_TOKEN=
# INFOBIP_API_KEY=
# INFOBIP_BASE_URL=https://api.infobip.com
# SMS_API_KEY=
# SMS_SENDER=EcoPet


# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE STORAGE (alternativa ao Cloudinary — ainda não implementado)
# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=ecopet-uploads


# ═══════════════════════════════════════════════════════════════════════════════
# TALKJS — chat (opcional)
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_TALKJS_APP_ID=
TALKJS_SECRET_KEY=
# TALKJS_WEBHOOK_VERIFY=1


