# Supabase PostgreSQL â€” pooler :6543 (runtime Prisma)
# Usada em: packages/database/prisma/schema.prisma, packages/database/src/client.ts
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ConexÃ£o direta :5432 â€” APENAS migrations (prisma migrate deploy) e CI
# NÃ£o Ã© usada em runtime serverless, mas deve existir no CI/local
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Segredo JWT do cookie ecopet-session (middleware Edge + /api/auth/*)
# Gere com: openssl rand -base64 32
AUTH_SECRET=change-me-in-production-auth-secret-min-32-chars

# Fallback NextAuth â€” pode ser IGUAL a AUTH_SECRET ou omitido se AUTH_SECRET existir
NEXTAUTH_SECRET=change-me-in-production-nextauth-min-32-chars

# URL pÃºblica HTTPS â€” NÃƒO use localhost na Vercel
# Exemplo: https://ecopet-web.vercel.app ou https://seudominio.com
NEXTAUTH_URL=https://ecopet-web.vercel.app
APP_URL=https://ecopet-web.vercel.app
NEXT_PUBLIC_APP_URL=https://ecopet-web.vercel.app


