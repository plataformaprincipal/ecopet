# ═══════════════════════════════════════════════════════════════════════════════
# DEBUG / TESTES — NUNCA em Production
# ═══════════════════════════════════════════════════════════════════════════════
# NODE_ENV=development                   # Vercel define production automaticamente
# UPLOAD_DEV_FALLBACK=1                  # upload local sem Cloudinary (só dev)
# FORCE_INSECURE_SESSION_COOKIE=1        # cookie sem Secure em HTTP local
# AUTH_RATE_LIMIT_RELAXED=1
# RATE_LIMIT_FORCE=1
# AUTH_TEST_EXPOSE_OTP=1
# AUTH_TEST_OTP_TTL_MS=500
# ALLOW_TEST_RESEND=1
# ECOPET_PROXY_LOG=1
# ECOPET_DISABLE_MOCK_PARTNERS=1
# ECOPET_ADMIN_WEBHOOK_URL=

# ─── Variáveis injetadas automaticamente pela Vercel (NÃO configurar) ───
# VERCEL=1
# VERCEL_URL=ecopet-web-xxx.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=ecopet-web.vercel.app
